# example of .env file

# RPC mainnet and testnet endpoints
RPC_ENDPOINT="https://eth-mainnet.g.alchemy.com/v2/{YOUR_ALCHEMY_API_KEY}"

# Uniswap V3 QuoterV2 (mainnet default in code: 0x61fFE014bA17989E743c5F6cB21bF9697530B21e).
# Override only if you point RPC at another chain or custom deployment.
# UNISWAP_V3_QUOTER_V2=0x...

# Multicall3 is fixed in chain/multicall.py (0xcA11bde05977b3631167028862bE2a173976CA11).

# Optional: Uniswap V2 subgraph for scripts/pricing_best_route.py --discover fetch
# To test routes on almost all pairs on mainnet and not a hardcoded pool of pairs.
THEGRAPH_API_KEY=your_the_graph_studio_key
SEPOLIA_RPC="https://eth-sepolia.g.alchemy.com/v2/{YOUR_ALCHEMY_API_KEY}"
# WebSocket mainnet: mempool monitor (pricing-mempool), V2 price feed (pricing-ws-feed),
# and any tool using chain.ws_env.resolve_websocket_url (MAINNET_WS / WS_URL / …).
MAINNET_WS="wss://eth-mainnet.g.alchemy.com/v2/{YOUR_ALCHEMY_API_KEY}"


# Test recipient address
TEST_RECIPIENT=0x000000000000000000000000000000000000dEaD

# Private key and address
PRIVATE_KEY=0x_your_private_key_here
ADDRESS=your_address_here

BINANCE_TESTNET_API_KEY=your_binance_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_binance_testnet_secret_here

# Bybit testnet (spot) — for multi-exchange tools and inventory dashboard.
BYBIT_TESTNET_API_KEY=your_bybit_testnet_api_key_here
BYBIT_TESTNET_SECRET=your_bybit_testnet_secret_here

# Optional: override default log path (default is logs/lab1.log under cwd)
LOG_FILE=logs/lab1.log

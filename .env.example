# example of .env file

# RPC — point at Arbitrum One (chain 42161) for low-cost Uniswap V2 (same ABI as Ethereum).
RPC_ENDPOINT="https://arb-mainnet.g.alchemy.com/v2/{YOUR_ALCHEMY_API_KEY}"
# Or public: https://arb1.arbitrum.io/rpc

# Uniswap V2 router (optional). Code defaults to Arbitrum One router below; set this for Ethereum mainnet.
# UNISWAP_V2_ROUTER=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D

# Reference (Arbitrum One): CHAIN_ID=42161, router 0x4752ba5dbc23f44d87826276bf6fd6b1c372ad24,
# WETH 0x82aF49447D8a07e3bd95BD0d56f35241523fBab1, native USDC 0xaf88d065e77c8cC2239327C5EDb3A432268e5831.
#
# V2 pool address = factory.getPair(WETH, USDC) (same as Week 2; order of tokens does not matter).
# Uniswap V2 Factory (Arbitrum): 0xf1D7CC64Fb4452F05c498126312eBE29f30Fbcf9
# If Uniswap V2 liquidity is thin, SushiSwap V2 uses the same pair/router ABI on Arbitrum:
#   Factory 0xc35DADB65012eC5796536bD9864eD8773aBc74C4  Router 0x1b02dA8Cb0d097eB8D57A175b88c7D8b47997506

# Uniswap V3 QuoterV2 (override if RPC is not the chain your Quoter deployment is on).
# UNISWAP_V3_QUOTER_V2=0x...

# Multicall3 is fixed in chain/multicall.py (0xcA11bde05977b3631167028862bE2a173976CA11).

SEPOLIA_RPC="https://eth-sepolia.g.alchemy.com/v2/{YOUR_ALCHEMY_API_KEY}"
# WebSocket mainnet: mempool monitor (pricing-mempool), V2 price feed (pricing-ws-feed),
# and any tool using chain.ws_env.resolve_websocket_url (MAINNET_WS / WS_URL / …).
MAINNET_WS="wss://eth-mainnet.g.alchemy.com/v2/{YOUR_ALCHEMY_API_KEY}"


# Test recipient address
TEST_RECIPIENT=0x000000000000000000000000000000000000dEaD

# Private key and address
PRIVATE_KEY=0x_your_private_key_here
ADDRESS=your_address_here

# Binance Spot — set PRODUCTION=true for api.binance.com; false for testnet.
# PRODUCTION=false (default): testnet keys
BINANCE_TESTNET_API_KEY=your_binance_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_binance_testnet_secret_here
# PRODUCTION=true: live keys (store the secret here — same CCXT field name ``secret``)
BINANCE_API_KEY=your_binance_production_api_key_here
BINANCE_API_SECRET=your_binance_production_secret_key_here

# Bybit testnet (spot) — for multi-exchange tools and inventory dashboard.
BYBIT_TESTNET_API_KEY=your_bybit_testnet_api_key_here
BYBIT_TESTNET_SECRET=your_bybit_testnet_secret_here

# Optional: override default log path (default is logs/lab1.log under cwd)
LOG_FILE=logs/lab1.log

# --- Arbitrage bot (scripts/arb_bot.py) --------------------------------------
# Telegram alerts: set TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Configuration for the Arbitrage bot

# Circuit breaker trip: POST JSON (see executor/webhook_alerts.circuit_breaker_payload).
# ARB_CIRCUIT_WEBHOOK_URL takes precedence over ARB_WEBHOOK_URL.
# ARB_CIRCUIT_WEBHOOK_URL=https://hooks.example.com/alert
# ARB_WEBHOOK_URL=https://hooks.example.com/alert
# ARB_WEBHOOK_TIMEOUT_SECONDS=5

# Prometheus metrics (optional: pip install lab1[metrics] or prometheus-client).
# PROMETHEUS_METRICS_PORT=9108

# Priority queue: max tradable signals executed per tick after sorting (CLI overrides).
# ARB_MAX_SIGNALS_PER_TICK=3

# Live Uniswap V2 router swaps (only when bot runs with --live, pricing + resolver loaded).
# DEX_LIVE_ENABLED=0
# DEX_EXPECTED_CHAIN_ID=42161
# DEX_ALLOW_MAINNET=0
# DEX_SLIPPAGE_BPS=50
# DEX_DEADLINE_SECONDS=300
# DEX_RUN_PREFLIGHT=1

# Risk & monitoring (scripts/arb_bot.py)
# ARB_INITIAL_CAPITAL=100
# CEX taker in basis points for signal/executor fee math. When unset, the bot calls
# CCXT fetch_trading_fee per --pairs and uses the maximum taker (matches IOC arb).
# ARB_CEX_TAKER_BPS=10
# ARB_KILL_SWITCH_FILE=/tmp/arb_bot_kill   # Linux lab default; Windows: set to a writable path
# ARB_KILL_SWITCH_POLL_SEC=5             # max seconds between kill-file checks during inter-tick sleep
# ARB_AUTO_CAPITAL_EMERGENCY_STOP=1       # optional: stop if inventory USD < ABSOLUTE_MIN_CAPITAL (50)
# ARB_DRY_RUN=1           # or CLI --dry-run: enables dry-run pipeline (see ARB_DRY_RUN_MODE)
# ARB_DRY_RUN_MODE=log|signed   # 'log' (default) skips executor entirely;
#                                # 'signed' runs route + fork preflight + EIP-1559 build +
#                                # signing on the DEX leg, but never broadcasts. CEX leg
#                                # stays simulated, so no real Binance order is sent.
# ARB_VIRTUAL_BALANCES=ETH=2,USDC=5000        # dry-run-only WALLET inventory override
# ARB_VIRTUAL_CEX_BALANCES=USDC=5000,ETH=2     # dry-run-only CEX (Binance) inventory override
# ARB_POOL_REFRESH_SECONDS=5     # cadence for re-reading V2 pool reserves so DEX prices track live LP activity (0=disable)
# ARB_TRADE_CSV=logs/trades_journal.csv   # default path; rich trade/dry-run/failure rows
# Signal detection (live / dry-run; demo ignores these — uses DEMO_SIGNAL_CONFIG):
# ARB_MIN_SPREAD_BPS=50       # default in generator: 50 — real arb vs Uniswap is often narrower
# ARB_MIN_PROFIT_USD=5        # default 5 — with fixed gas in FeeStructure, small notionals never pass
# ARB_MAX_POSITION_USD=10000  # caps trade size for inventory / grid search
# ARB_SIGNAL_COOLDOWN_SECONDS=2
# ARB_SIGNAL_TTL_SECONDS=5
# ARB_TRADE_CSV_DISABLED=1               # disable CSV journal
# Put both in repo-root .env (loaded at bot startup). Chat ID: message @userinfobot or forward to @getidsbot; for groups use supergroup id (often negative).
# TELEGRAM_CONTROLS_ENABLED=1   # slash commands: /pause /resume /stop_bot /status /help /set (same chat only)
# TELEGRAM_CONTROL_POLL_SEC=3   # seconds between getUpdates polls
# ARB_HALT_ON_CONSECUTIVE_LOSSES=1   # exit process loop after N losing trades (N = ARB_CONSECUTIVE_LOSS_LIMIT); urgent Telegram
# ARB_TELEGRAM_NOTIFY_OPPORTUNITIES=1   # Telegram when a tick has scored candidates (throttled)
# ARB_TELEGRAM_OPPORTUNITY_COOLDOWN_SEC=300
# Soft risk limits (optional; defaults in risk/limits.py)
# ARB_MAX_TRADE_USD=10
# ARB_MAX_DAILY_LOSS_USD=10
# ARB_MAX_TRADES_PER_HOUR=20
# ARB_CONSECUTIVE_LOSS_LIMIT=3
# Post-trade balance check (live, non-dry-run only): refetch vs InventoryTracker
# ARB_BALANCE_VERIFY_DISABLED=1
# ARB_BALANCE_VERIFY_TOLERANCE=0.001
